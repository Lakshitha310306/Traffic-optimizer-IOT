<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             http://maven.apache.org/xsd/maven-4.0.0.xsd">

  <modelVersion>4.0.0</modelVersion>

  <!-- ── Project identity ──────────────────────────────────────────── -->
  <groupId>com.trafficoptimizer</groupId>
  <artifactId>traffic-optimizer</artifactId>
  <version>1.0.0</version>
  <packaging>jar</packaging>
  <name>People-First Smart City Traffic Optimizer</name>
  <description>
    Multi-objective IoT traffic optimizer using a Pareto-front genetic algorithm.
    Jointly optimizes vehicle flow and pedestrian safety across a simulated 4x4 city grid.
    IoT Course Project.
  </description>

  <!-- ── Global properties ─────────────────────────────────────────── -->
  <properties>
    <maven.compiler.source>17</maven.compiler.source>
    <maven.compiler.target>17</maven.compiler.target>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <javafx.version>21.0.1</javafx.version>
    <junit.version>5.10.1</junit.version>
  </properties>

  <!-- ── Dependencies ──────────────────────────────────────────────── -->
  <dependencies>

    <!-- JavaFX Controls — buttons, sliders, labels, charts -->
    <dependency>
      <groupId>org.openjfx</groupId>
      <artifactId>javafx-controls</artifactId>
      <version>${javafx.version}</version>
    </dependency>

    <!-- JavaFX FXML — layout support -->
    <dependency>
      <groupId>org.openjfx</groupId>
      <artifactId>javafx-fxml</artifactId>
      <version>${javafx.version}</version>
    </dependency>

    <!-- JavaFX Swing bridge — Canvas rendering on some JDKs -->
    <dependency>
      <groupId>org.openjfx</groupId>
      <artifactId>javafx-swing</artifactId>
      <version>${javafx.version}</version>
    </dependency>

    <!-- JUnit 5 — unit testing for GA, sensors, model classes -->
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter-api</artifactId>
      <version>${junit.version}</version>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter-engine</artifactId>
      <version>${junit.version}</version>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter-params</artifactId>
      <version>${junit.version}</version>
      <scope>test</scope>
    </dependency>

  </dependencies>

  <!-- ── Build plugins ─────────────────────────────────────────────── -->
  <build>
    <plugins>

      <!-- 1. Java compiler — enforce Java 17 -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.11.0</version>
        <configuration>
          <source>17</source>
          <target>17</target>
          <encoding>UTF-8</encoding>
        </configuration>
      </plugin>

      <!-- 2. JavaFX Maven plugin — run dashboard with: mvn javafx:run -->
      <plugin>
        <groupId>org.openjfx</groupId>
        <artifactId>javafx-maven-plugin</artifactId>
        <version>0.0.8</version>
        <configuration>
          <mainClass>com.trafficoptimizer.Main</mainClass>
          <options>
            <option>--add-opens=java.base/java.lang=ALL-UNNAMED</option>
            <option>--add-opens=java.base/java.util=ALL-UNNAMED</option>
          </options>
        </configuration>
      </plugin>

      <!-- 3. Exec plugin — console mode with: mvn exec:java -->
      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>exec-maven-plugin</artifactId>
        <version>3.1.0</version>
        <configuration>
          <mainClass>com.trafficoptimizer.Main</mainClass>
          <arguments>
            <argument>--console</argument>
          </arguments>
        </configuration>
      </plugin>

      <!-- 4. Shade plugin — fat runnable JAR with: mvn package -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.5.1</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals><goal>shade</goal></goals>
            <configuration>
              <transformers>
                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                  <mainClass>com.trafficoptimizer.Main</mainClass>
                </transformer>
              </transformers>
              <createDependencyReducedPom>false</createDependencyReducedPom>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <!-- 5. Surefire — run JUnit 5 tests with: mvn test -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.1.2</version>
        <configuration>
          <useModulePath>false</useModulePath>
        </configuration>
      </plugin>

    </plugins>
  </build>

</project>